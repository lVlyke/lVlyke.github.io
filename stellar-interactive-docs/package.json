{
  "name": "stellar-mod-loader",
  "author": "Mychal Thompson <mychal.r.thompson@gmail.com>",
  "repository": "https://github.com/lVlyke/stellar-mod-loader",
  "license": "GPL-3.0",
  "version": "0.15.0-beta.0",
  "main": "electron/main.js",
  "scripts": {
    "build": "node ./scripts/build.cjs",
    "build:release": "npm run build -- --release",
    "game-db:generate-schema": "ts-json-schema-generator --path ./src/app/models/game-database.ts --type GameDatabase > game-db.schema.json",
    "docs:generate-schema": "ts-json-schema-generator --path ./src/app/models/interactive-docs/topic.ts --type AppInteractiveDocsTopics > interactive-docs.schema.json",
    "package:prepare": "node ./scripts/pre-package.cjs",
    "package:portable:debug": "npm run package:prepare && node ./scripts/package-portable.cjs",
    "package:portable:debug:all": "npm run package:portable:debug -- --all",
    "package:portable:release": "npm run package:prepare -- --release && node ./scripts/package-portable.cjs",
    "package:portable:release:all": "npm run package:portable:release -- --all",
    "package:flatpak:debug": "npm run package:prepare && node ./scripts/package-flatpak.cjs",
    "package:flatpak:debug:all": "npm run package:flatpak:debug -- --all",
    "package:flatpak:release": "npm run package:prepare && node ./scripts/package-flatpak.cjs",
    "package:flatpak:release:all": "npm run package:flatpak:release -- --all",
    "package:debug": "npm run package:flatpak:debug",
    "package:debug:all": "npm run package:flatpak:debug:all",
    "package:release": "npm run package:flatpak:release",
    "package:release:all": "npm run package:flatpak:release:all",
    "ng": "./node_modules/.bin/ng",
    "serve": "node ./scripts/serve.cjs",
    "serve:release": "npm run serve -- --release",
    "predocs:serve": "node ./scripts/copy-assets.cjs",
    "docs:build": "npm run build -- --docs",
    "docs:build:release": "npm run docs:build -- --release",
    "docs:serve": "npm run ng serve interactive-docs",
    "docs:serve:release": "npm run serve:docs -- --configuration production",
    "start": "npm run serve",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron-win32-install": "npm remove electron && npm install && export npm_config_platform=win32 && npm install --save-dev electron@^37.10.0 && unset npm_config_platform"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.16",
    "@angular/cdk": "~20.2.14",
    "@angular/common": "^20.3.16",
    "@angular/compiler": "^20.3.16",
    "@angular/core": "^20.3.16",
    "@angular/forms": "^20.3.16",
    "@angular/material": "~20.2.14",
    "@angular/platform-browser": "^20.3.16",
    "@angular/platform-browser-dynamic": "^20.3.16",
    "@angular/router": "^20.3.16",
    "@lithiumjs/angular": "^8.0.2",
    "@lithiumjs/ngx-material-theming": "^1.0.0",
    "@lithiumjs/ngx-virtual-scroll": "^0.3.4",
    "@ngxs/store": "^20.1.0",
    "detect-file-encoding-and-language": "^2.4.0",
    "electron-log": "^5.4.3",
    "es-toolkit": "^1.41.0",
    "fs-extra": "^11.3.2",
    "ini": "^6.0.0",
    "mime-types": "^3.0.1",
    "node-7z": "^3.0.0",
    "rxjs": "~7.8.2",
    "steam-binary-vdf": "^0.1.0",
    "tslib": "^2.3.0",
    "which": "^6.0.0",
    "win-version-info": "^6.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@angular/build": "^20.3.12",
    "@angular/cli": "^20.3.15",
    "@angular/compiler-cli": "^20.3.16",
    "@electron/packager": "^19.0.2",
    "@ngxs/devtools-plugin": "^20.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/ini": "^4.1.1",
    "@types/jasmine": "~5.1.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.1",
    "@types/node-7z": "^2.1.11",
    "@types/which": "^3.0.4",
    "@types/win-version-info": "^3.1.3",
    "@types/xml2js": "^0.4.14",
    "baseline-browser-mapping": "^2.9.19",
    "chokidar": "^4.0.3",
    "electron": "^37.10.0",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "ts-json-schema-generator": "^2.4.0",
    "typescript": "~5.8.3"
  },
  "browser": {
    "fs": false,
    "path": false,
    "os": false
  }
}
